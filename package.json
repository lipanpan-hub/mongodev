{
  "name": "@lppx/mongodev",
  "description": "a dev tool for mongodb",
  "version": "0.0.0",
  "author": "lppx",
  "bin": {
    "mgd": "./bin/run.js"
  },
  "bugs": "https://github.com/lipanpan-hub/mongodev/issues",
  "dependencies": {
    "@oclif/core": "^4",
    "@oclif/plugin-autocomplete": "^3.2.50",
    "@oclif/plugin-help": "^6",
    "@oclif/plugin-not-found": "^3.2.86",
    "@oclif/plugin-version": "^2.2.46",
    "@oclif/plugin-warn-if-update-available": "^3.1.65",
    "cli-table3": "^0.6.5",
    "mongodb": "^7.2.0",
    "prompts": "^2.4.2"
  },
  "devDependencies": {
    "@eslint/compat": "^1",
    "@oclif/prettier-config": "^0.2.1",
    "@oclif/test": "^4",
    "@types/chai": "^4",
    "@types/mocha": "^10",
    "@types/node": "^18",
    "@types/prompts": "^2.4.9",
    "chai": "^4",
    "eslint": "^9",
    "eslint-config-oclif": "^6",
    "eslint-config-prettier": "^10",
    "mocha": "^11",
    "oclif": "^4",
    "shx": "^0.3.3",
    "ts-node": "^10",
    "typescript": "^5"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "files": [
    "./bin",
    "./dist",
    "./oclif.manifest.json"
  ],
  "homepage": "https://github.com/lipanpan-hub/mongodev",
  "keywords": [
    "oclif"
  ],
  "license": "BSL",
  "main": "dist/index.js",
  "type": "module",
  "oclif": {
    "bin": "mgd",
    "dirname": "mongodev",
    "commands": "./dist/commands",
    "plugins": [
      "@oclif/plugin-help",
      "@oclif/plugin-warn-if-update-available",
      "@oclif/plugin-autocomplete",
      "@oclif/plugin-not-found",
      "@oclif/plugin-version"
    ],
    "topicSeparator": " ",
    "nsisCustomization": "nsis/nsis.nsi",
    "topics": {
      "hello": {
        "description": "Say hello to the world and others"
      }
    },
    "hooks": {
      "init": "./dist/hooks/init/inithook"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": "lipanpan-hub/mongodev",
  "scripts": {
    "build": "shx rm -rf dist && tsc -b",
    "lint": "eslint",
    "postpack": "shx rm -f oclif.manifest.json",
    "posttest": "npm run lint",
    "prepack": "oclif manifest && oclif readme",
    "test": "mocha --forbid-only \"test/**/*.test.ts\"",
    "version": "oclif readme && git add README.md",
    "pack:tarballs": "oclif pack tarballs",
    "pack:win": "oclif pack win",
    "pack:macos": "oclif pack macos",
    "pack:deb": "oclif pack deb"
  },
  "types": "dist/index.d.ts"
}
